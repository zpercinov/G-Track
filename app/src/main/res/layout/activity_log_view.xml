<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/log_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/login_background_hf_style">

    <!-- HEADER isti kao tvoj prethodni -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <ImageView
            android:id="@+id/imgAccount"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_preview_button"
            android:contentDescription="@string/app_name"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/txtAccount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/log_label"
            android:textColor="@color/narandzasta"
            android:textStyle="bold"
            android:textSize="24sp"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/imgAccount"
            app:layout_constraintEnd_toStartOf="@id/btnIzlazLog"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"/>

        <ImageButton
            android:id="@+id/btnIzlazLog"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@color/narandzasta"

            android:importantForAccessibility="no"
            android:src="@drawable/ic_logout_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CalendarView -->
    <CalendarView
        android:id="@+id/calendarView"
        style="@style/CalendarViewCustom"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/rounded_corner_orange"/>

    <TextView
        android:id="@+id/tvBrojac"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="@string/brojac"
        android:textColor="@color/bela"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/rounded_corner_orange"
        android:layout_marginBottom="8dp"/>

    <!-- TabLayout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabIndicatorColor="@color/narandzasta"
        app:tabSelectedTextColor="@color/siva"
        app:tabTextAppearance="@style/MyTabText"
        app:tabTextColor="@color/narandzasta"
        tools:ignore="SpeakableTextPresentCheck" />

    <!-- Dva RecyclerView-a, jedan po tab -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_corner_orange"
        android:scrollbars="vertical"
        android:visibility="visible"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerZaposlen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_corner_orange"
        android:scrollbars="vertical"
        android:visibility="gone"/>
</LinearLayout>
